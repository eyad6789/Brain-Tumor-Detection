# Base path the browser uses to reach the API. Default "/api" is proxied to the
# FastAPI backend by next.config.ts rewrites (same-origin, no CORS in dev).
# For a split-host deployment, point this at the backend, e.g. https://api.example.com
NEXT_PUBLIC_API_BASE=/api

# Where the Next.js dev rewrite proxies /api/* to. Change if the backend isn't local.
BACKEND_ORIGIN=http://127.0.0.1:8000
